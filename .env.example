# Financial Modeling Prep API key (required)
FMP_API_KEY=

# Contact email declared to SEC EDGAR in the User-Agent header (required)
EDGAR_CONTACT_EMAIL=

# Optional SMTP settings — only used when email.enabled: true in config.yaml
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
